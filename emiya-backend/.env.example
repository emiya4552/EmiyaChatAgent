# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60.0

# LLM 参数 — 各场景可独立调整
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=2000
EMOTION_TEMPERATURE=0.1
EMOTION_MAX_TOKENS=150
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=500
SUMMARY_BATCH_MESSAGES=8

# 数据库配置（与 docker-compose.yml 一致）
DB_PASSWORD=emiya_dev_2026
DATABASE_URL=postgresql+asyncpg://emiya:emiya_dev_2026@localhost:5432/emiya

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# 前端地址（找回密码邮件里的重置链接会使用它）
FRONTEND_BASE_URL=http://localhost:5173

# SMTP 邮件配置（找回密码）
# STARTTLS: SMTP_PORT=587, SMTP_USE_TLS=true, SMTP_USE_SSL=false
# SSL:      SMTP_PORT=465, SMTP_USE_TLS=false, SMTP_USE_SSL=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=EMIYA
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# 应用配置
APP_ENV=development
LOG_LEVEL=INFO

# MVU double-ai update pass
# Empty MVU_UPDATE_MODEL means reuse DEEPSEEK_MODEL.
MVU_UPDATE_MODEL=
MVU_UPDATE_TEMPERATURE=0.2
MVU_UPDATE_MAX_TOKENS=1000
MVU_UPDATE_FORCE_TOOL=true
MVU_BROWSER_RUNTIME=false
