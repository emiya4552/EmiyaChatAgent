# ============================================================
# EMIYA 后端环境变量
# 使用：cp .env.example .env
#
# 快速开始（本地开发）：
#   1) 在仓库根目录 docker compose up -d   # 起 postgres / redis / chromadb（端口已与下方默认值对齐）
#   2) 只需填【必填】里的 DEEPSEEK_API_KEY，其余保持默认即可启动
#   3) 生产环境务必把 JWT_SECRET_KEY 改成长随机串
# ============================================================

# ===== 【必填】DeepSeek API =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key        # ← 必填：你的 DeepSeek key
DEEPSEEK_MODEL=deepseek-chat                      # ← 必填（无默认值）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TIMEOUT=60.0

# ===== 【本地默认已可用】数据库（值与 docker-compose.yml 一致）=====
DB_PASSWORD=emiya_dev_2026
DATABASE_URL=postgresql+asyncpg://emiya:emiya_dev_2026@localhost:5432/emiya

# ===== 【本地默认已可用】JWT =====
# 生产必须改：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ===== 【本地默认已可用】Redis / ChromaDB（记忆系统向量库）=====
# 端口与 docker-compose.yml 一致（chromadb 宿主端口映射为 8001）。
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ===== 【可选】LLM 参数（均有默认，按需微调）=====
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=2000
EMOTION_TEMPERATURE=0.1
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=500
SUMMARY_BATCH_MESSAGES=8

# ===== 【可选】SMTP 邮件（仅"找回密码"功能用；不配则该功能不可用，不影响启动）=====
FRONTEND_BASE_URL=http://localhost:5173
# 取消注释并填写以启用邮件。STARTTLS: PORT=587/USE_TLS=true；SSL: PORT=465/USE_SSL=true
# SMTP_HOST=smtp.example.com
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_PORT=587
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=EMIYA
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ===== 【可选】应用 / 日志 =====
APP_ENV=development
LOG_LEVEL=INFO

# ===== 【可选】MVU double-ai update pass =====
# MVU_UPDATE_MODEL 留空 = 复用 DEEPSEEK_MODEL
MVU_UPDATE_MODEL=
MVU_UPDATE_TEMPERATURE=0.2
MVU_UPDATE_MAX_TOKENS=1000
MVU_UPDATE_FORCE_TOOL=true
MVU_BROWSER_RUNTIME=false
