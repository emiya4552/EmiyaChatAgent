{
  "name": "emiya-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prototype:home": "vite --config prototypes/immersive-home/vite.config.ts",
    "prototype:home:build": "vite build --config prototypes/immersive-home/vite.config.ts",
    "prototype:ui": "vite --config prototypes/ui-review/vite.config.ts",
    "prototype:ui:build": "vite build --config prototypes/ui-review/vite.config.ts",
    "prototype:conversation": "vite --config prototypes/conversation-surface/vite.config.ts",
    "prototype:conversation:build": "vite build --config prototypes/conversation-surface/vite.config.ts",
    "prototype:studio": "vite --config prototypes/creative-studio/vite.config.ts",
    "prototype:studio:build": "vite build --config prototypes/creative-studio/vite.config.ts",
    "prototype:insights": "vite --config prototypes/insight-atlas/vite.config.ts",
    "prototype:insights:build": "vite build --config prototypes/insight-atlas/vite.config.ts",
    "prototype:account": "vite --config prototypes/account-journey/vite.config.ts",
    "prototype:account:build": "vite build --config prototypes/account-journey/vite.config.ts",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.12.0",
    "axios": "^1.7.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "highlight.js": "^11.11.0",
    "marked": "^15.0.0",
    "naive-ui": "^2.40.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.1.0"
  }
}
